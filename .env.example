# =============================================
# NOVA CONFIGURATION — PRODUCTION
Copy to .env and fill in real values. NEVER commit .env!
# =============================================

# ── PostgreSQL Container ─────────────────────
POSTGRES_DB=nova_db
POSTGRES_USER=nova_user
POSTGRES_PASSWORD=change_me_to_secure_password
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=en_US.UTF-8

# ── Database Connection ───────────────────────
DATABASE_URL=postgresql://nova_user:change_me_to_secure_password@nova-postgres:5432/nova_db

# ── Redis Connection ──────────────────────────
REDIS_HOST=nova-redis
REDIS_PORT=6379
# REDIS_PASSWORD=   # uncomment if Redis requires auth

# ── Auth ─────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change_me_to_a_secure_secret_min_32_chars
BETTER_AUTH_URL=http://localhost:17492
NOVA_BASE_URL=http://localhost:17492
NOVA_TRUSTED_ORIGIN=http://localhost:17492

# ── OAuth Providers (optional) ────────────────
NOVA_AUTH_GITHUB_ID=
NOVA_AUTH_GITHUB_SECRET=
NOVA_AUTH_GOOGLE_ID=
NOVA_AUTH_GOOGLE_SECRET=
NOVA_AUTH_DISCORD_ID=
NOVA_AUTH_DISCORD_SECRET=
NOVA_AUTH_MICROSOFT_ID=
NOVA_AUTH_MICROSOFT_SECRET=
NOVA_AUTH_MICROSOFT_TENANT_ID=
NOVA_AUTH_GITLAB_ID=
NOVA_AUTH_GITLAB_SECRET=
NOVA_AUTH_GITLAB_ISSUER=
NOVA_AUTH_APPLE_ID=
NOVA_AUTH_APPLE_SECRET=
NOVA_AUTH_TWITTER_ID=
NOVA_AUTH_TWITTER_SECRET=

# ── SMTP (optional — for password reset emails) ─
NOVA_SMTP_HOST=
NOVA_SMTP_PORT=587
NOVA_SMTP_USER=
NOVA_SMTP_PASSWORD=
NOVA_SMTP_FROM_EMAIL=

# ── Instance ──────────────────────────────────
NOVA_INSTANCE_NAME=NOVA

# ── General ───────────────────────────────────
COMPOSE_PROJECT_NAME=nova
